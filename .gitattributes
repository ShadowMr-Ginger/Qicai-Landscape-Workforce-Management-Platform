# 强制所有文本文件使用 LF 换行符，避免 Windows/Unix 混用导致的问题
* text=auto eol=lf

# 明确指定常见源码文件为 UTF-8 编码文本
*.java text encoding=utf-8
*.xml text encoding=utf-8
*.yml text encoding=utf-8
*.yaml text encoding=utf-8
*.properties text encoding=utf-8
*.sql text encoding=utf-8
*.ts text encoding=utf-8
*.tsx text encoding=utf-8
*.js text encoding=utf-8
*.jsx text encoding=utf-8
*.json text encoding=utf-8
*.css text encoding=utf-8
*.scss text encoding=utf-8
*.md text encoding=utf-8
*.sh text eol=lf
*.bat text eol=crlf

# 二进制文件不做处理
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.jar binary
*.zip binary
*.tar.gz binary
