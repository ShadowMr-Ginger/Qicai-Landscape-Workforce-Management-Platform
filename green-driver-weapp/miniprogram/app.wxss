@charset "UTF-8";
/* ==================== 设计令牌 / Design Tokens ==================== */
/* ==================== 全局样式 ==================== */
page {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  color: #1f2937;
  background-color: #f5f5f5;
  -webkit-font-smoothing: antialiased;
}

/* 容器 */
.container {
  padding: 24rpx;
}

.container-sm {
  padding: 16rpx;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
}

.card-hover {
  background: #f9fafb;
}

/* 按钮 - 主色 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.2s;
}

.btn-primary {
  background: linear-gradient(135deg, #16a34a, #15803d);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(22, 163, 74, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-primary[disabled] {
  background: #d1d5db;
  color: #6b7280;
  box-shadow: none;
}

.btn-outline {
  background: #ffffff;
  color: #16a34a;
  border: 2rpx solid #16a34a;
}

.btn-outline:active {
  background: #dcfce7;
}

.btn-danger {
  background: #ef4444;
  color: #ffffff;
}

.btn-sm {
  height: 64rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  padding: 0 24rpx;
}

/* 表单输入 */
.input {
  height: 88rpx;
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.input:focus {
  border-color: #16a34a;
  background: #ffffff;
}

.input-placeholder {
  color: #9ca3af;
}

/* 文本 */
.text-xs {
  font-size: 22rpx;
}

.text-sm {
  font-size: 24rpx;
}

.text-base {
  font-size: 28rpx;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}

.text-2xl {
  font-size: 40rpx;
}

.font-medium {
  font-weight: 500;
}

.font-semibold {
  font-weight: 600;
}

.font-bold {
  font-weight: 700;
}

.text-gray-400 {
  color: #9ca3af;
}

.text-gray-500 {
  color: #6b7280;
}

.text-gray-600 {
  color: #4b5563;
}

.text-gray-700 {
  color: #374151;
}

.text-gray-800 {
  color: #1f2937;
}

.text-primary {
  color: #16a34a;
}

.text-red-500 {
  color: #ef4444;
}

.text-orange-500 {
  color: #f97316;
}

/* 布局 */
.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.gap-2 {
  gap: 16rpx;
}

.gap-3 {
  gap: 24rpx;
}

.gap-4 {
  gap: 32rpx;
}

/* 间距 */
.mt-1 {
  margin-top: 8rpx;
}

.mt-2 {
  margin-top: 16rpx;
}

.mt-3 {
  margin-top: 24rpx;
}

.mt-4 {
  margin-top: 32rpx;
}

.mb-1 {
  margin-bottom: 8rpx;
}

.mb-2 {
  margin-bottom: 16rpx;
}

.mb-3 {
  margin-bottom: 24rpx;
}

.mb-4 {
  margin-bottom: 32rpx;
}

.ml-2 {
  margin-left: 16rpx;
}

.mr-2 {
  margin-right: 16rpx;
}

.p-2 {
  padding: 16rpx;
}

.p-3 {
  padding: 24rpx;
}

.p-4 {
  padding: 32rpx;
}

/* 徽章 */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-green {
  background: #dcfce7;
  color: #15803d;
}

.badge-orange {
  background: #fff7ed;
  color: #f97316;
}

.badge-red {
  background: #fef2f2;
  color: #dc2626;
}

.badge-blue {
  background: #eff6ff;
  color: #3b82f6;
}

.badge-purple {
  background: #f5f3ff;
  color: #8b5cf6;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: #e5e7eb;
  margin: 24rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-state-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-state-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
