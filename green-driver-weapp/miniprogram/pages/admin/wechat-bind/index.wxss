.bind-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.bind-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 80rpx 48rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.bind-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
}

.bind-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.bind-desc {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
  margin-bottom: 48rpx;
}

.bind-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #16a34a;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
}

.bind-btn::after {
  border: none;
}

.skip-text {
  margin-top: 32rpx;
  font-size: 26rpx;
  color: #9ca3af;
}
