<view class="login-page">
  <view class="login-header">
    <text class="back-btn" bindtap="goBack">← 返回</text>
  </view>
  <view class="login-card">
    <view class="logo-area">
      <view class="logo-icon">🌿</view>
      <text class="logo-title">绿化工人管理系统</text>
      <text class="logo-subtitle">管理后台登录</text>
    </view>
    <view class="form-area">
      <view class="form-item">
        <text class="form-label">账号</text>
        <input class="form-input" placeholder="请输入管理员账号" value="{{username}}" bindinput="onUsernameInput" />
      </view>
      <view class="form-item">
        <text class="form-label">密码</text>
        <input class="form-input" placeholder="请输入密码" password value="{{password}}" bindinput="onPasswordInput" />
      </view>
      <button class="login-btn" loading="{{loading}}" bindtap="onLogin">登录</button>
      <view class="divider">
        <view class="divider-line"></view>
        <text class="divider-text">或</text>
        <view class="divider-line"></view>
      </view>
      <button class="wx-login-btn" loading="{{wxLoading}}" bindtap="onWxLogin">🟢 微信一键登录</button>
    </view>
  </view>
</view>
