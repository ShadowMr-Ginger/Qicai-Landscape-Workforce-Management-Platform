@charset "UTF-8";
.batch-list-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 选项卡 */
.tab-bar {
  display: flex;
  background: #ffffff;
  border-bottom: 2rpx solid #f3f4f6;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #9ca3af;
  font-weight: 500;
  position: relative;
}

.tab-active {
  color: #16a34a;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 4rpx;
  background: #16a34a;
  border-radius: 2rpx;
}

.refresh-btn {
  padding: 24rpx;
  font-size: 32rpx;
}

/* 列表 */
.batch-list {
  padding: 24rpx;
}

.batch-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.batch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.batch-date {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.batch-count {
  font-size: 26rpx;
  color: #6b7280;
}

.batch-body {
  margin-bottom: 20rpx;
}

.batch-info-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.info-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.info-value {
  font-size: 24rpx;
  color: #4b5563;
}

/* 操作按钮 */
.batch-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f3f4f6;
}

.action-btn {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  text-align: center;
  background: transparent;
  border: 2rpx solid #e5e7eb;
  color: #6b7280;
}

.action-btn::after {
  border: none;
}

.action-btn.danger {
  color: #ef4444;
  border-color: #fecaca;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: #d1d5db;
}

/* 详情弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 80vh;
  padding: 32rpx;
  padding-bottom: 48rpx;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.modal-close {
  font-size: 36rpx;
  color: #9ca3af;
  padding: 8rpx;
}

.detail-info {
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.detail-label {
  font-size: 26rpx;
  color: #9ca3af;
}

.detail-value {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
}

.detail-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.detail-worker-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-worker-item {
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 24rpx;
}

.worker-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.worker-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.worker-type {
  font-size: 24rpx;
  color: #16a34a;
  background: #dcfce7;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.worker-info-row {
  padding: 4rpx 0;
}

.worker-info {
  font-size: 24rpx;
  color: #6b7280;
}

.worker-info-remark {
  font-size: 24rpx;
  color: #9ca3af;
  font-style: italic;
}
