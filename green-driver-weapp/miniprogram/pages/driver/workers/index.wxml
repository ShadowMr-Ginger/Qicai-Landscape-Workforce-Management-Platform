<view class="workers-page">
  <!-- 搜索栏 -->
  <view class="search-section">
    <view class="search-bar" wx:if="{{!showSearch}}" bindtap="toggleSearch">
      <text class="search-icon">🔍</text>
      <text class="search-text">搜索添加工人...</text>
      <text class="search-btn-text">添加</text>
    </view>

    <view class="search-panel" wx:if="{{showSearch}}">
      <view class="search-input-row">
        <input
          class="search-input"
          placeholder="输入姓名或手机号"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          confirm-type="search"
          bindconfirm="doSearch"
          focus
        />
        <text class="search-action" bindtap="doSearch">搜索</text>
        <text class="search-action cancel" bindtap="toggleSearch">取消</text>
      </view>
      <view class="search-results" wx:if="{{searchResults.length > 0}}">
        <view class="result-item" wx:for="{{searchResults}}" wx:key="id">
          <view class="result-info">
            <text class="result-name">{{item.name}}</text>
            <text class="result-phone">{{item.phone || ''}}</text>
          </view>
          <button class="add-btn" bindtap="onAddWorker" data-id="{{item.id}}">+ 添加</button>
        </view>
      </view>
      <view class="search-empty" wx:if="{{searchKeyword && searchResults.length === 0}}">
        <text>未找到匹配工人</text>
      </view>
    </view>
  </view>

  <!-- 常用工人列表 -->
  <view class="favorites-section">
    <view class="section-header">
      <text class="section-title">我的常用工人</text>
      <text class="section-count">{{favoriteWorkers.length}}人</text>
    </view>

    <view class="worker-list">
      <view class="worker-card" wx:for="{{favoriteWorkers}}" wx:key="id">
        <view class="worker-avatar">
          <text class="avatar-text">{{item.name[0]}}</text>
        </view>
        <view class="worker-info">
          <text class="worker-name">{{item.name}}</text>
          <text class="worker-phone">{{item.phone || ''}}</text>
        </view>
        <button class="remove-btn" bindtap="onRemoveWorker" data-id="{{item.id}}">移除</button>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{favoriteWorkers.length === 0 && !loading}}">
      <text class="empty-icon">👷</text>
      <text class="empty-text">还没有常用工人</text>
      <text class="empty-sub">点击上方搜索添加工人</text>
    </view>
  </view>
</view>
