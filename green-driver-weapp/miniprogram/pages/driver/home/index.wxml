<view class="home-page">
  <!-- 顶部问候 -->
  <view class="home-header">
    <view class="header-greeting">
      <text class="greeting-text">你好，{{displayName}}</text>
      <text class="greeting-date">{{todayStr}}</text>
    </view>
    <view class="header-avatar">
      <text class="avatar-text">{{avatarLetter}}</text>
    </view>
  </view>

  <!-- 快捷统计 -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-num">{{draftCount}}</text>
      <text class="stat-label">草稿批次</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{pendingCount}}</text>
      <text class="stat-label">待审核</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{approvedCount}}</text>
      <text class="stat-label">本月通过</text>
    </view>
  </view>

  <!-- 主要操作 -->
  <view class="action-grid">
    <view class="action-card primary" bindtap="goCreateBatch">
      <view class="action-icon-wrapper primary-bg">
        <text class="action-icon">✏️</text>
      </view>
      <view class="action-info">
        <text class="action-title">上报考勤</text>
        <text class="action-desc">记录今日工人出勤情况</text>
      </view>
      <text class="action-arrow">›</text>
    </view>

    <view class="action-card" bindtap="goBatchList">
      <view class="action-icon-wrapper blue-bg">
        <text class="action-icon">📋</text>
      </view>
      <view class="action-info">
        <text class="action-title">批次记录</text>
        <text class="action-desc">查看和管理历史批次</text>
      </view>
      <text class="action-arrow">›</text>
    </view>

    <view class="action-card" bindtap="goWorkers">
      <view class="action-icon-wrapper orange-bg">
        <text class="action-icon">👷</text>
      </view>
      <view class="action-info">
        <text class="action-title">常用工人</text>
        <text class="action-desc">管理我的常用工人列表</text>
      </view>
      <text class="action-arrow">›</text>
    </view>
  </view>
</view>
